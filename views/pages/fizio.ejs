<div class="ic"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg></div>
<div><div class="tag">Igrači</div><div class="tl">Prvi pregled</div><div class="ds">Kompletan pregled bez naknade</div></div>
<div class="bg">0€</div>
</div>
<div class="fi-card">
<div class="ic"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg></div>
<div><div class="tag">Igrači</div><div class="tl">Prva terapija</div><div class="ds">Potpuno besplatna tretman</div></div>
<div class="bg">0€</div>
</div>
