<div class="hero-actions">
<a href="tel:+385993334040" class="btn btn-red">Naruči se <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
<a href="https://www.fizioterapijarestart.hr" target="_blank" rel="noopener" class="btn btn-wo">Službena stranica</a>
</div>
</div>
</section>

<!-- FIZIO MAIN CONTENT -->
<section class="fizio">
<div class="container">
<div class="fizio-head gs">
