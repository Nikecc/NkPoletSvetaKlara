d.innerHTML=`<div class="pd-vis"><div class="pd-glow"></div><img src="${p.img}" alt="${p.name}"><div class="pd-bgn">${p.num}</div></div>
<div class="pd-info"><div class="pd-num">${p.num}</div><div class="pd-pos">${p.pos}</div>
<h2 class="pd-name">${p.name.split(' ').slice(0,-1).join(' ')}<br>${p.name.split(' ').pop()}</h2>
<div class="pd-stats"><div class="pd-stat"><div class="val">${p.apps}</div><div class="lbl">Utakmice</div></div><div class="pd-stat"><div class="val">${p.goals}</div><div class="lbl">Golovi</div></div><div class="pd-stat"><div class="val">${p.mins}<span class="u">'</span></div><div class="lbl">Minute</div></div><div class="pd-stat"><div class="val">${p.yc}</div><div class="lbl">Žuti kartoni</div></div></div>
<div class="pd-meta"><div class="pd-mi"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17.657 16.657L13.414 20.9a2 2 0 01-2.828 0l-4.243-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>${p.nat}</div><div class="pd-mi"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>${p.age} god.</div><div class="pd-mi"><img src="${LOGO}" alt="">NK Polet • 2025/26</div></div></div>`;
gsap.from(d.querySelector('.pd-vis img'),{scale:.85,opacity:0,duration:.7,ease:'power3.out'});
gsap.from(d.querySelector('.pd-bgn'),{x:80,opacity:0,duration:.8,ease:'power3.out',delay:.1});
gsap.from(d.querySelector('.pd-info'),{x:40,opacity:0,duration:.6,ease:'power3.out',delay:.15})}
function scrollT(d){document.getElementById('pThumbs').scrollBy({left:d*300,behavior:'smooth'})}
function scrollN(d){document.getElementById('newsScroll').scrollBy({left:d*310,behavior:'smooth'})}
// Hero
let hI=0;function showS(i){const s=document.querySelectorAll('.hero-slide'),d=document.querySelectorAll('.hero-dot'),l=s.length;hI=((i%l)+l)%l;s.forEach((x,j)=>x.classList.toggle('active',j===hI));d.forEach((x,j)=>x.classList.toggle('active',j===hI))}
function heroSlide(dir){showS(hI+dir)}
document.querySelectorAll('.hero-dot').forEach(d=>d.addEventListener('click',()=>showS(+d.dataset.slide)));
setInterval(()=>heroSlide(1),6000);
// Nav
// Smooth scroll
document.querySelectorAll('a[href^="#"]').forEach(a=>{a.addEventListener('click',e=>{e.preventDefault();const t=document.querySelector(a.getAttribute('href'));if(t)t.scrollIntoView({behavior:'smooth',block:'start'});closeMenu()})});
// Scorers bar animation
function animBars(){const obs=new IntersectionObserver(entries=>{entries.forEach(e=>{if(e.isIntersecting){const el=e.target,g=el.dataset.goals,m=el.dataset.max;el.querySelector('.sc-bar-fill').style.width=(g/m*100)+'%';obs.unobserve(el)}})},{threshold:.3});document.querySelectorAll('.sc-bar-item').forEach(r=>obs.observe(r))}
// GSAP
function initG(){gsap.registerPlugin(ScrollTrigger);
gsap.utils.toArray('.gs').forEach(el=>{gsap.fromTo(el,{opacity:0,y:50},{opacity:1,y:0,duration:.8,ease:'power3.out',scrollTrigger:{trigger:el,start:'top 92%'}})});
gsap.utils.toArray('.gsl').forEach(el=>{gsap.fromTo(el,{opacity:0,x:-50},{opacity:1,x:0,duration:.8,ease:'power3.out',scrollTrigger:{trigger:el,start:'top 92%'}})});
gsap.utils.toArray('.gss').forEach(el=>{gsap.fromTo(el,{opacity:0,scale:.92},{opacity:1,scale:1,duration:.8,ease:'power3.out',scrollTrigger:{trigger:el,start:'top 92%'}})})}
// Scroll table to Polet row on load
setTimeout(()=>{const ts=document.querySelector('.tbl-scroll');const hl=document.querySelector('.tbl tr.hl');if(ts&&hl){ts.scrollTop=hl.offsetTop-ts.offsetHeight/2+hl.offsetHeight/2}},2500);
window.addEventListener('load',()=>{buildT();selP(0);animBars();setTimeout(()=>{document.getElementById('preloader').classList.add('hide');setTimeout(()=>document.getElementById('preloader').remove(),700)},2000);setTimeout(initG,100)});
</script>
<%- include('../partials/nav-js') %>
</body>
</html>
