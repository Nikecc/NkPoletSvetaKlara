<!DOCTYPE html>
<html lang="hr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Seniorska momčad — NK Polet Sveta Klara</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@300;400;500;600;700;800;900&family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
--blue:#1B2A4A;--blue-l:#2C4470;--blue-d:#0F1A30;
--red:#D42428;--red-l:#E84E52;--red-d:#A01C1F;
--dark:#0B0F18;--dark-2:#111827;--dark-3:#1A2233;--dark-4:#212B3E;
--light:#F7F7F8;--light-2:#EEEEF0;--cream:#FAFAF9;--white:#FFF;
--td:#1A1A2E;--td2:#4A5568;--td3:#717D8F;
--border:rgba(255,255,255,.06);--bl:rgba(0,0,0,.06);
--r:12px;
--fh:'Barlow Condensed',sans-serif;--fb:'Inter',sans-serif;--fm:'JetBrains Mono',monospace;
}
html{scroll-behavior:smooth;overflow-x:hidden}
body{font-family:var(--fb);background:var(--light);color:var(--td);overflow-x:hidden;-webkit-font-smoothing:antialiased}
h1,h2,h3,h4,h5{font-family:var(--fh);text-transform:uppercase;letter-spacing:.02em}
.container{max-width:1320px;margin:0 auto;padding:0 48px}
@media(max-width:768px){.container{padding:0 20px}}
img{display:block;max-width:100%}a{color:inherit;text-decoration:none}
.sec{padding:100px 0}
.sec-title{font-size:clamp(2rem,4vw,2.8rem);font-weight:800;letter-spacing:.03em}
/* Pitch line decoration */
.pitch-divider{display:flex;align-items:center;justify-content:center;gap:1.5rem;padding:0 0 48px}
.pitch-divider::before,.pitch-divider::after{content:'';flex:1;height:1px;background:var(--bl)}
.pitch-divider .cm{width:36px;height:36px;border:1.5px solid rgba(0,0,0,.08);border-radius:50%;position:relative}
.pitch-divider .cm::after{content:'';width:5px;height:5px;background:rgba(0,0,0,.1);border-radius:50%;position:absolute;top:50%;left:50%;transform:translate(-50%,-50%)}
.pitch-divider.light::before,.pitch-divider.light::after{background:rgba(255,255,255,.08)}
.pitch-divider.light .cm{border-color:rgba(255,255,255,.1)}
.pitch-divider.light .cm::after{background:rgba(255,255,255,.15)}
/* Goal net texture */
.net-bg{position:relative}
.net-bg::after{content:'';position:absolute;inset:0;background-image:repeating-linear-gradient(45deg,transparent,transparent 12px,rgba(255,255,255,.015) 12px,rgba(255,255,255,.015) 13px),repeating-linear-gradient(-45deg,transparent,transparent 12px,rgba(255,255,255,.015) 12px,rgba(255,255,255,.015) 13px);pointer-events:none;z-index:0}

/* ===== PRELOADER ===== */
#preloader{position:fixed;inset:0;z-index:99999;background:var(--dark);display:flex;flex-direction:column;align-items:center;justify-content:center;transition:opacity .6s,visibility .6s}
#preloader.hide{opacity:0;visibility:hidden}
#preloader .plogo{width:100px;animation:pp 1.5s ease-in-out infinite}
@keyframes pp{0%,100%{transform:scale(1)}50%{transform:scale(1.06)}}
#preloader .bar{width:120px;height:2px;background:var(--dark-3);border-radius:2px;margin-top:24px;overflow:hidden}
#preloader .bar i{display:block;width:0;height:100%;background:linear-gradient(90deg,var(--red),var(--red-l));border-radius:2px;animation:lb 1.8s ease forwards}
@keyframes lb{to{width:100%}}
#preloader .ptxt{font-family:var(--fh);font-size:1.2rem;color:rgba(255,255,255,.3);letter-spacing:.25em;margin-top:16px;text-transform:uppercase}

/* ===== NAV ===== */
.nav{position:fixed;top:0;left:0;right:0;z-index:1000;height:72px;display:flex;align-items:center;padding:0 48px;transition:all .4s}
.nav::after{content:'';position:absolute;inset:0;background:rgba(11,15,24,.94);backdrop-filter:blur(20px);opacity:0;transition:opacity .4s;z-index:-1}
.nav.scrolled::after{opacity:1}
.nav.scrolled{border-bottom:1px solid var(--border)}
.ni{display:flex;align-items:center;justify-content:space-between;width:100%}
.nav-left{display:flex;align-items:center;gap:40px}
.nav-brand{display:flex;align-items:center;gap:12px}
.nav-crest{width:52px;height:52px;flex-shrink:0;transition:transform .3s}.nav-crest img{width:100%;height:100%;object-fit:contain}
.nav-brand:hover .nav-crest{transform:scale(1.08) rotate(3deg)}
.nav-name{font-family:var(--fh);font-size:1.3rem;font-weight:700;color:#fff;letter-spacing:.1em}
.nav-links{display:flex;gap:28px;list-style:none}
.nav-links a{font-size:.78rem;font-weight:600;color:var(--td3);text-transform:uppercase;letter-spacing:.08em;transition:color .3s;position:relative;font-family:var(--fb)}
.nav-links a:hover{color:#fff}
.nav-links a::after{content:'';position:absolute;bottom:-4px;left:0;width:0;height:2px;background:var(--red);transition:width .3s}
.nav-links a:hover::after{width:100%}
.nav-right{display:flex;align-items:center;gap:16px}
.nav-social a{width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center;color:var(--td3);transition:all .3s}
.nav-social a:hover{color:#fff;background:rgba(255,255,255,.06)}
.nav-toggle{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:5px}
.nav-toggle span{width:20px;height:1.5px;background:#fff;transition:all .3s;border-radius:1px}
.nav-toggle.active span:nth-child(1){transform:rotate(45deg) translate(4.5px,4.5px)}
.nav-toggle.active span:nth-child(2){opacity:0}
.nav-toggle.active span:nth-child(3){transform:rotate(-45deg) translate(4.5px,-4.5px)}
@media(max-width:1024px){.nav{padding:0 20px}.nav-toggle{display:flex;z-index:10001}.nav-links{position:fixed;inset:0;background:rgba(11,15,24,.97);flex-direction:column;align-items:center;justify-content:center;gap:32px;opacity:0;pointer-events:none;transition:opacity .4s;z-index:10000}.nav-links.open{opacity:1;pointer-events:all}.nav-links a{font-size:1.3rem}.nav-social{display:none}}

/* ===== HERO (100vh) ===== */
.hero{position:relative;height:100vh;overflow:hidden}
.hero-slides{position:absolute;inset:0}
.hero-slide{position:absolute;inset:0;opacity:0;transition:opacity 1.2s}.hero-slide.active{opacity:1}
.hero-slide img{width:100%;height:100%;object-fit:cover}
.hero-ov{position:absolute;inset:0;background:linear-gradient(90deg,rgba(11,15,24,.9) 0%,rgba(11,15,24,.5) 45%,rgba(11,15,24,.15) 100%),linear-gradient(180deg,transparent 40%,rgba(11,15,24,.8) 100%);z-index:1}
.hero-crest{position:absolute;right:8%;top:50%;transform:translateY(-50%);z-index:2;width:320px;height:320px;opacity:.08;pointer-events:none;filter:brightness(2)}
.hero-crest img{width:100%;height:100%;object-fit:contain}
.hero-content{position:absolute;bottom:0;left:0;right:0;z-index:2;padding:0 48px 100px}
.hero-tag{display:inline-flex;align-items:center;gap:8px;padding:8px 20px;border-radius:4px;background:var(--red);font-size:.7rem;font-weight:700;color:#fff;text-transform:uppercase;letter-spacing:.12em;margin-bottom:24px;font-family:var(--fb)}
.hero-title{font-size:clamp(3.5rem,8vw,6.5rem);font-weight:900;line-height:.92;color:#fff;margin-bottom:16px;max-width:750px}
.hero-title .thin{font-weight:300;color:rgba(255,255,255,.5)}
.hero-desc{font-size:1.05rem;color:rgba(255,255,255,.5);max-width:480px;line-height:1.7;margin-bottom:32px;font-weight:300}
.hero-btn{display:inline-flex;align-items:center;gap:10px;padding:16px 40px;background:var(--red);border:none;color:#fff;font-family:var(--fh);font-size:1rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;border-radius:4px;transition:all .3s;cursor:pointer}
.hero-btn:hover{background:#fff;color:var(--red);transform:translateY(-2px);box-shadow:0 12px 40px rgba(0,0,0,.3)}
.hero-btn svg{transition:transform .3s}.hero-btn:hover svg{transform:translateX(4px)}
.hero-scroll{position:absolute;bottom:32px;left:50%;transform:translateX(-50%);z-index:3;display:flex;flex-direction:column;align-items:center;gap:8px;color:rgba(255,255,255,.3);font-size:.6rem;letter-spacing:.2em;text-transform:uppercase;font-family:var(--fb);font-weight:600}
.hero-scroll .line{width:1px;height:32px;background:linear-gradient(rgba(255,255,255,.3),transparent);animation:scrollL 2s ease infinite}
@keyframes scrollL{0%{transform:scaleY(1);opacity:1}100%{transform:scaleY(0);opacity:0;transform-origin:bottom}}
.hero-pager{position:absolute;bottom:100px;right:48px;z-index:3;display:flex;gap:8px}
.hero-dot{width:32px;height:3px;border-radius:2px;background:rgba(255,255,255,.2);cursor:pointer;transition:all .4s}
.hero-dot.active{width:52px;background:var(--red)}
@media(max-width:768px){.hero-content{padding:0 20px 120px}.hero-pager{right:20px;bottom:60px}.hero-scroll{bottom:16px}.hero-crest{width:180px;height:180px;right:5%}}

/* ===== NEWS (Juve tall cards) ===== */
.news{background:var(--white);padding:60px 0 40px}
.news .sec-title{color:var(--td)}
.news-scroll{display:flex;gap:16px;overflow-x:auto;padding:8px 0;scroll-snap-type:x mandatory;-ms-overflow-style:none;scrollbar-width:none}
.news-scroll::-webkit-scrollbar{display:none}
.nc{flex-shrink:0;width:280px;height:440px;scroll-snap-align:start;border-radius:16px;overflow:hidden;position:relative;cursor:pointer;transition:transform .4s}
.nc:hover{transform:translateY(-8px)}
.nc img{width:100%;height:100%;object-fit:cover;transition:transform .6s}
.nc:hover img{transform:scale(1.05)}
.nc-ov{position:absolute;inset:0;background:linear-gradient(180deg,transparent 25%,rgba(10,15,25,.9) 100%);display:flex;flex-direction:column;justify-content:flex-end;padding:28px 24px}
.nc-ov .cat{font-family:var(--fb);font-size:.6rem;font-weight:700;color:var(--red-l);text-transform:uppercase;letter-spacing:.12em;margin-bottom:10px}
.nc-ov h3{font-family:var(--fh);font-size:1.3rem;font-weight:700;color:#fff;line-height:1.15;margin-bottom:16px;text-transform:uppercase}
.nc-btn{display:inline-flex;padding:10px 20px;background:#fff;color:var(--td);font-family:var(--fh);font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;border-radius:3px;transition:all .3s;align-self:flex-start}
.nc:hover .nc-btn{background:var(--red);color:#fff}
.news-bot{display:flex;justify-content:space-between;align-items:center;margin-top:28px}
.news-arrows{display:flex;gap:8px}
.news-arrows button{width:48px;height:48px;border-radius:50%;background:none;border:1.5px solid var(--bl);color:var(--td3);cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .3s}
.news-arrows button:hover{border-color:var(--td);color:var(--td)}
.news-all{font-family:var(--fh);font-size:.9rem;font-weight:600;color:var(--td3);text-transform:uppercase;letter-spacing:.1em;display:flex;align-items:center;gap:10px;transition:color .3s}
.news-all:hover{color:var(--red)}

/* ===== FIXTURES & TABLE ===== */
.fixtures{background:var(--white);border-top:none;padding:40px 0 100px}
.fixtures .sec-title{color:var(--td)}
.fix-grid{display:grid;grid-template-columns:1fr;gap:40px}
.fix-list{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:10px}
.fix-card{background:var(--light);border:1px solid var(--bl);border-radius:10px;padding:14px 18px;display:grid;grid-template-columns:1fr auto 1fr;gap:14px;align-items:center;transition:all .3s;position:relative;overflow:hidden}
.fix-card::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px}
.fix-card.w::before{background:#22c55e}.fix-card.d::before{background:#f59e0b}.fix-card.next::before{background:var(--red)}
.fix-card:hover{background:var(--light-2);transform:translateX(3px)}
.fix-team{display:flex;align-items:center;gap:8px}.fix-team.right{justify-content:flex-end;text-align:right}
.fix-badge{width:24px;height:24px;flex-shrink:0}.fix-badge img{width:100%;height:100%;object-fit:contain}
.fix-badge.opp{width:24px;height:24px;border-radius:5px;background:var(--light-2);display:flex;align-items:center;justify-content:center;font-family:var(--fh);font-size:10px;color:var(--td3)}
.fix-tname{font-family:var(--fh);font-size:.9rem;font-weight:600;color:var(--td);letter-spacing:.02em}
.fix-center{text-align:center}
.fix-score{font-family:var(--fm);font-size:1.1rem;font-weight:700;color:var(--td)}
.fix-date{font-size:.58rem;color:var(--td3);margin-top:1px;font-family:var(--fm)}
.fix-vs{font-family:var(--fh);font-size:1rem;color:var(--td3)}
/* table */
.tcard{background:var(--light);border:1px solid var(--bl);border-radius:var(--r);overflow:hidden}
.tcard-h{padding:18px 24px;border-bottom:1px solid var(--bl);font-family:var(--fh);font-size:1.2rem;font-weight:700;color:var(--td);letter-spacing:.05em;display:flex;align-items:center;gap:10px}
.tcard-h img{width:22px;height:22px;object-fit:contain}
.tbl-scroll{max-height:340px;overflow-y:auto;scrollbar-width:thin;scrollbar-color:var(--red-l) var(--light-2)}
.tbl-scroll::-webkit-scrollbar{width:4px}
.tbl-scroll::-webkit-scrollbar-track{background:var(--light-2)}
.tbl-scroll::-webkit-scrollbar-thumb{background:var(--red-l);border-radius:4px}
.tbl{width:100%;border-collapse:collapse}
.tbl th{font-family:var(--fb);font-size:.68rem;font-weight:700;color:var(--td3);text-transform:uppercase;letter-spacing:.08em;padding:12px 14px;text-align:left;border-bottom:1px solid var(--bl);position:sticky;top:0;background:var(--light);z-index:1}
.tbl td{padding:12px 14px;font-size:.88rem;border-bottom:1px solid var(--bl);color:var(--td2);font-family:var(--fb)}
.tbl tr:last-child td{border-bottom:none}
.tbl .pos{font-family:var(--fm);font-weight:700;color:var(--td3);width:28px;font-size:.82rem}
.tbl .team{font-family:var(--fh);font-weight:600;color:var(--td);font-size:.95rem;letter-spacing:.02em}
.tbl .pts{font-family:var(--fm);font-weight:700;color:var(--td);font-size:.88rem}
.tbl .num{font-family:var(--fm);font-size:.82rem}
.tbl tr.hl{background:rgba(212,36,40,.05)}
.tbl tr.hl td{border-bottom-color:rgba(212,36,40,.08)}
.tbl tr.hl .team{color:var(--red)}.tbl tr.hl .pts{color:var(--red)}

/* ===== SQUAD (ROMA) ===== */
.squad{background:var(--light);padding:60px 0 0;overflow:hidden}
.squad-title-wrap{text-align:center;margin-bottom:32px}
.squad-title{font-family:var(--fh);font-size:clamp(4rem,10vw,8rem);font-weight:900;color:transparent;-webkit-text-stroke:2.5px var(--td);letter-spacing:.06em;line-height:1;margin-bottom:4px}
.squad .sec-sub{color:var(--td3);font-family:var(--fb);font-size:.78rem;font-weight:600;text-transform:uppercase;letter-spacing:.08em;text-align:center}
.player-thumbs-wrap{position:relative;margin-bottom:0}
.player-thumbs{display:flex;gap:24px;overflow-x:auto;padding:16px 48px 24px;-ms-overflow-style:none;scrollbar-width:none;scroll-snap-type:x mandatory;justify-content:flex-start}
.player-thumbs::-webkit-scrollbar{display:none}
.pt{flex-shrink:0;text-align:center;cursor:pointer;scroll-snap-align:start;transition:all .3s}
.pt-c{width:88px;height:100px;border-radius:8px;overflow:hidden;margin:0 auto 8px;border:2.5px solid transparent;transition:all .4s;position:relative;background:var(--light-2)}
.pt.active .pt-c{border-color:var(--red);box-shadow:0 4px 20px rgba(212,36,40,.15)}
.pt:hover .pt-c{border-color:rgba(0,0,0,.08)}
.pt-c img{width:100%;height:100%;object-fit:cover;object-position:center top}
.pt-n{font-family:var(--fh);font-size:.75rem;font-weight:600;color:var(--td3);transition:color .3s;max-width:90px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.pt.active .pt-n{color:var(--td)}
.tn{position:absolute;top:50%;transform:translateY(-60%);width:36px;height:36px;border-radius:50%;background:var(--white);border:1px solid var(--bl);color:var(--td);cursor:pointer;display:flex;align-items:center;justify-content:center;z-index:5;transition:all .3s;box-shadow:0 2px 10px rgba(0,0,0,.08)}
.tn:hover{background:var(--red);border-color:var(--red);color:#fff}
.tn.left{left:8px}.tn.right{right:8px}
/* Player detail */
.pd{display:grid;grid-template-columns:1fr 1fr;min-height:540px;background:var(--dark-2);position:relative;overflow:hidden}
.pd::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 25% 80%,rgba(212,36,40,.05),transparent 50%);z-index:0}
.pd-vis{position:relative;display:flex;align-items:flex-end;justify-content:center;z-index:1}
.pd-vis img{position:relative;z-index:2;max-height:500px;width:auto;max-width:90%;object-fit:contain;filter:drop-shadow(0 10px 40px rgba(0,0,0,.4))}
.pd-bgn{position:absolute;font-family:var(--fh);font-size:24rem;font-weight:900;line-height:1;color:rgba(255,255,255,.025);right:-30px;bottom:-20px;z-index:1;user-select:none}
.pd-glow{position:absolute;width:300px;height:300px;border-radius:50%;background:radial-gradient(circle,rgba(27,42,74,.15),transparent 70%);top:50%;left:50%;transform:translate(-50%,-50%);z-index:0}
.pd-info{display:flex;flex-direction:column;justify-content:center;padding:60px;position:relative;z-index:1}
.pd-num{font-family:var(--fh);font-size:8rem;font-weight:900;color:rgba(255,255,255,.05);line-height:1;margin-bottom:-28px}
.pd-pos{font-family:var(--fh);font-size:.85rem;font-weight:600;text-transform:uppercase;letter-spacing:.25em;color:var(--red-l);margin-bottom:8px}
.pd-name{font-family:var(--fh);font-size:clamp(2.5rem,5vw,4.2rem);font-weight:900;color:#fff;line-height:1;margin-bottom:24px}
.pd-stats{display:flex;gap:36px;margin-bottom:32px}
.pd-stat .val{font-family:var(--fh);font-size:2.2rem;font-weight:800;color:#fff}
.pd-stat .val .u{font-size:.9rem;color:var(--td3);font-weight:400}
.pd-stat .lbl{font-family:var(--fb);font-size:.6rem;color:var(--td3);text-transform:uppercase;letter-spacing:.12em;margin-top:2px}
.pd-meta{display:flex;gap:12px;flex-wrap:wrap}
.pd-mi{padding:8px 16px;background:rgba(255,255,255,.04);border:1px solid var(--border);border-radius:8px;font-size:.72rem;color:var(--td3);display:flex;align-items:center;gap:6px;font-family:var(--fb)}
.pd-mi svg{width:14px;height:14px;color:rgba(255,255,255,.25)}
.pd-mi img{width:16px;height:16px;object-fit:contain}
@media(max-width:900px){.pd{grid-template-columns:1fr}.pd-vis{height:360px;padding-top:20px}.pd-vis img{max-height:330px}.pd-info{padding:32px 24px 48px}.pd-bgn{font-size:14rem}.pd-num{font-size:5rem}}

/* ===== TOP SCORERS (animated bars) ===== */
.scorers{background:var(--dark);position:relative;overflow:hidden}
.scorers::after{content:'';position:absolute;inset:0;background-image:repeating-linear-gradient(45deg,transparent,transparent 12px,rgba(255,255,255,.012) 12px,rgba(255,255,255,.012) 13px),repeating-linear-gradient(-45deg,transparent,transparent 12px,rgba(255,255,255,.012) 12px,rgba(255,255,255,.012) 13px);pointer-events:none}
.scorers .container{position:relative;z-index:1}
.scorers .sec-title{color:#fff}
.scorers-grid{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center}
@media(max-width:900px){.scorers-grid{grid-template-columns:1fr}}
.sc-hero{position:relative;text-align:center}
.sc-hero-img{width:240px;height:280px;margin:0 auto;position:relative}
.sc-hero-img img{width:100%;height:100%;object-fit:contain;filter:drop-shadow(0 10px 40px rgba(0,0,0,.4));position:relative;z-index:2}
.sc-hero-num{position:absolute;font-family:var(--fh);font-size:12rem;font-weight:900;color:rgba(255,255,255,.03);top:50%;left:50%;transform:translate(-50%,-50%);z-index:1}
.sc-hero-glow{position:absolute;width:200px;height:200px;border-radius:50%;background:radial-gradient(circle,rgba(212,36,40,.12),transparent 70%);top:50%;left:50%;transform:translate(-50%,-50%);z-index:0}
.sc-hero-info{margin-top:16px}
.sc-hero-info .crown{font-size:.7rem;color:var(--red-l);text-transform:uppercase;letter-spacing:.2em;font-family:var(--fb);font-weight:700;margin-bottom:4px}
.sc-hero-info h3{font-family:var(--fh);font-size:2rem;font-weight:800;color:#fff}
.sc-hero-info .goals-big{font-family:var(--fh);font-size:3.5rem;font-weight:900;color:var(--red-l);line-height:1;margin-top:4px}
.sc-hero-info .goals-lbl{font-family:var(--fb);font-size:.6rem;color:var(--td3);text-transform:uppercase;letter-spacing:.15em}
/* Bars */
.sc-bars{display:flex;flex-direction:column;gap:16px}
.sc-bar-item{display:grid;grid-template-columns:56px 1fr 48px;gap:14px;align-items:center}
.sc-ava{width:56px;height:56px;border-radius:50%;overflow:hidden;border:2px solid rgba(255,255,255,.06);background:var(--dark-3)}
.sc-ava img{width:100%;height:100%;object-fit:cover}
.sc-bar-wrap{}
.sc-bar-name{font-family:var(--fh);font-size:.9rem;font-weight:700;color:#fff;letter-spacing:.03em;margin-bottom:6px}
.sc-bar-track{height:8px;background:rgba(255,255,255,.06);border-radius:4px;overflow:hidden}
.sc-bar-fill{height:100%;border-radius:4px;width:0;transition:width 1.5s cubic-bezier(.22,1,.36,1)}
.sc-bar-fill.r1{background:linear-gradient(90deg,var(--red),var(--red-l))}
.sc-bar-fill.r2{background:linear-gradient(90deg,var(--blue),var(--blue-l))}
.sc-bar-fill.r3{background:linear-gradient(90deg,#1a5c3a,#22c55e)}
.sc-bar-fill.r4{background:linear-gradient(90deg,#7c3aed,#a78bfa)}
.sc-goals{font-family:var(--fm);font-size:1.3rem;font-weight:700;color:#fff;text-align:right}

/* ===== NAŠA PRIČA ===== */
.story{background:var(--blue);position:relative;overflow:hidden}
.story::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 70% 50%,rgba(44,68,112,.5),transparent 60%)}
.story-grid{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center;position:relative;z-index:1}
.story-text .sl{font-family:var(--fb);font-size:.65rem;font-weight:700;color:var(--red-l);text-transform:uppercase;letter-spacing:.2em;margin-bottom:12px}
.story-text h2{font-family:var(--fh);font-size:clamp(2rem,4vw,3.2rem);font-weight:900;color:#fff;margin-bottom:20px;line-height:1.05}
.story-text p{color:rgba(255,255,255,.55);line-height:1.8;margin-bottom:14px;font-size:.92rem}
.story-stats{display:flex;gap:28px;margin-top:32px;padding-top:28px;border-top:1px solid rgba(255,255,255,.1)}
.story-stat .v{font-family:var(--fh);font-size:2.4rem;font-weight:900;color:#fff}
.story-stat .l{font-family:var(--fb);font-size:.55rem;color:rgba(255,255,255,.35);text-transform:uppercase;letter-spacing:.12em;margin-top:2px}
/* Field */
.field-wrap{position:relative;width:100%;aspect-ratio:1.5/1;max-width:520px;margin:0 auto}
.field-svg{width:100%;height:100%}
.fl{fill:none;stroke:rgba(255,255,255,.2);stroke-width:1.5}
.fc{fill:none;stroke:rgba(255,255,255,.2);stroke-width:1.5}
.ff{fill:rgba(255,255,255,.025)}
.ball{fill:var(--red-l);filter:drop-shadow(0 0 12px rgba(232,78,82,.35))}
.field-badge{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:90px;height:90px;opacity:.12}
.field-badge img{width:100%;height:100%;object-fit:contain}
@keyframes mb{0%{cx:120;cy:90}15%{cx:200;cy:50}30%{cx:280;cy:110}50%{cx:350;cy:70}65%{cx:300;cy:130}80%{cx:220;cy:80}100%{cx:120;cy:90}}
.ball{animation:mb 8s ease-in-out infinite}
.fd{fill:rgba(255,255,255,.25);animation:fda 2s ease-in-out infinite}
.fd:nth-child(2){animation-delay:.3s}.fd:nth-child(3){animation-delay:.6s}.fd:nth-child(4){animation-delay:.9s}.fd:nth-child(5){animation-delay:1.2s}
@keyframes fda{0%,100%{r:3;opacity:.25}50%{r:5;opacity:.6}}
@media(max-width:900px){.story-grid{grid-template-columns:1fr}.field-wrap{margin-top:40px}}

/* ===== STADIUM ===== */
.stadium{background:var(--cream);border-top:1px solid var(--bl)}
.stadium .sec-title{color:var(--td)}
.stad-wrap{display:grid;grid-template-columns:1.2fr 1fr;gap:0;border-radius:20px;overflow:hidden;box-shadow:0 12px 50px rgba(0,0,0,.06);min-height:440px}
.stad-img{position:relative;overflow:hidden}.stad-img img{width:100%;height:100%;object-fit:cover;min-height:440px}
.stad-img-ov{position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(11,15,24,.7) 100%);display:flex;flex-direction:column;justify-content:flex-end;padding:36px}
.stad-img-ov h3{font-family:var(--fh);font-size:clamp(1.6rem,3vw,2.4rem);font-weight:800;color:#fff}
.stad-img-ov p{color:rgba(255,255,255,.55);font-size:.82rem;margin-top:4px}
.stad-info{background:var(--blue);padding:48px 40px;display:flex;flex-direction:column;justify-content:center;gap:20px}
.stad-item{display:flex;gap:14px;align-items:flex-start}
.stad-icon{width:40px;height:40px;border-radius:10px;background:rgba(255,255,255,.06);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.stad-icon svg{width:18px;height:18px;color:var(--red-l)}
.stad-item h4{font-family:var(--fh);font-size:.9rem;font-weight:700;color:#fff;margin-bottom:2px;letter-spacing:.03em}
.stad-item p{font-family:var(--fb);font-size:.72rem;color:rgba(255,255,255,.45);line-height:1.5}
.stad-contact{margin-top:8px;padding-top:20px;border-top:1px solid rgba(255,255,255,.08)}
.stad-contact a{display:inline-flex;align-items:center;gap:6px;color:rgba(255,255,255,.45);font-size:.75rem;margin-right:20px;transition:color .3s;font-family:var(--fb)}
.stad-contact a:hover{color:#fff}
@media(max-width:900px){.stad-wrap{grid-template-columns:1fr}}

/* ===== ŠKOLA NOGOMETA ===== */
.academy{background:var(--white);position:relative;overflow:hidden;padding:0}
.acad-inner{display:grid;grid-template-columns:1fr 1fr;align-items:stretch}
.acad-img{position:relative;overflow:hidden;max-height:760px}
.acad-img img{width:100%;height:100%;object-fit:cover}
.acad-img-ov{position:absolute;inset:0;background:linear-gradient(135deg,rgba(212,36,40,.8) 0%,rgba(27,42,74,.9) 100%);display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:48px}
.acad-img-ov .acad-big-num{font-family:var(--fh);font-size:6rem;font-weight:900;color:rgba(255,255,255,.15);line-height:1}
.acad-img-ov .acad-big-lbl{font-family:var(--fb);font-size:.65rem;color:rgba(255,255,255,.5);text-transform:uppercase;letter-spacing:.2em;margin-top:4px}
.acad-img-ov .acad-logo{width:80px;height:80px;margin-top:32px;opacity:.3}
.acad-img-ov .acad-logo img{width:100%;height:100%;object-fit:contain}
.acad-content{background:var(--light);padding:36px 48px;display:flex;flex-direction:column;justify-content:center}
.acad-content .sl{font-family:var(--fb);font-size:.65rem;font-weight:700;color:var(--red);text-transform:uppercase;letter-spacing:.2em;margin-bottom:12px}
.acad-content h2{font-family:var(--fh);font-size:clamp(2rem,4vw,3rem);font-weight:900;color:var(--td);margin-bottom:16px;line-height:1.05}
.acad-content p{color:var(--td2);line-height:1.8;margin-bottom:14px;font-size:.92rem}
.acad-age-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin:20px 0 28px}
.acad-age{padding:14px 12px;background:var(--white);border:1px solid var(--bl);border-radius:10px;text-align:center;transition:all .3s;cursor:pointer}
.acad-age:hover{border-color:var(--red);transform:translateY(-3px);box-shadow:0 8px 24px rgba(212,36,40,.08)}
.acad-age .age-name{font-family:var(--fh);font-size:.95rem;font-weight:700;color:var(--td);letter-spacing:.04em}
.acad-age .age-count{font-family:var(--fb);font-size:.62rem;color:var(--td3);font-weight:500;margin-top:2px}
.hero-btn-red{display:inline-flex;align-items:center;gap:10px;padding:16px 40px;background:var(--red);border:none;color:#fff;font-family:var(--fh);font-size:1rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;border-radius:4px;transition:all .3s;cursor:pointer;text-decoration:none}
.hero-btn-red:hover{background:var(--td);transform:translateY(-2px);box-shadow:0 12px 40px rgba(0,0,0,.15)}
@media(max-width:900px){.acad-inner{grid-template-columns:1fr}.acad-img{min-height:300px}.acad-content{padding:40px 24px}.acad-age-grid{grid-template-columns:repeat(2,1fr)}}

/* ===== CTA ===== */
.cta-bar{background:linear-gradient(135deg,var(--red-d),var(--red));padding:60px 0;position:relative;overflow:hidden}
.cta-bar::before{content:'POLET';position:absolute;font-family:var(--fh);font-size:14rem;font-weight:900;color:rgba(255,255,255,.04);right:-30px;top:50%;transform:translateY(-50%);white-space:nowrap}
.cta-inner{display:flex;align-items:center;justify-content:space-between;gap:24px;flex-wrap:wrap;position:relative;z-index:1}
.cta-inner h2{font-family:var(--fh);font-size:clamp(1.6rem,3vw,2.4rem);font-weight:800;color:#fff}
.cta-inner p{color:rgba(255,255,255,.55);max-width:400px;font-size:.9rem}
.cta-btns{display:flex;gap:12px;flex-wrap:wrap}
.btn-w{padding:16px 40px;background:#fff;color:var(--red);font-family:var(--fh);font-size:1rem;font-weight:700;letter-spacing:.08em;border:none;border-radius:4px;cursor:pointer;transition:all .3s;text-decoration:none;text-transform:uppercase}
.btn-w:hover{background:var(--dark);color:#fff;transform:translateY(-2px);box-shadow:0 8px 30px rgba(0,0,0,.2)}
.btn-wo{padding:16px 40px;background:transparent;color:#fff;font-family:var(--fh);font-size:1rem;font-weight:700;letter-spacing:.08em;border:1.5px solid rgba(255,255,255,.3);border-radius:4px;cursor:pointer;transition:all .3s;text-decoration:none;text-transform:uppercase}
.btn-wo:hover{background:rgba(255,255,255,.1);border-color:rgba(255,255,255,.5)}
@media(max-width:768px){.cta-inner{flex-direction:column;text-align:center}}

/* ===== FOOTER ===== */
.footer{background:var(--blue-d);padding:60px 0 24px}
.ft{display:grid;grid-template-columns:2fr 1fr 1fr 1.3fr;gap:40px;padding-bottom:40px;border-bottom:1px solid rgba(255,255,255,.06)}
.foot-brand .fbl{display:flex;align-items:center;gap:10px;margin-bottom:12px}
.foot-brand .fbc{width:40px;height:40px}.foot-brand .fbc img{width:100%;height:100%;object-fit:contain}
.foot-brand .fbn{font-family:var(--fh);font-size:1.1rem;font-weight:700;color:#fff;letter-spacing:.06em}
.foot-brand p{color:var(--td3);font-size:.78rem;line-height:1.7;max-width:260px}
.foot-col h4{font-family:var(--fb);font-size:.6rem;font-weight:700;color:var(--td3);text-transform:uppercase;letter-spacing:.15em;margin-bottom:16px}
.foot-col ul{list-style:none}.foot-col li{margin-bottom:10px}
.foot-col a{color:rgba(255,255,255,.45);font-size:.78rem;transition:color .3s}.foot-col a:hover{color:var(--red-l)}
.fb{display:flex;justify-content:space-between;align-items:center;padding-top:20px;flex-wrap:wrap;gap:12px}
.fb p{font-size:.62rem;color:var(--td3)}
.fs{display:flex;gap:8px}
.fsa{width:34px;height:34px;border-radius:8px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);display:flex;align-items:center;justify-content:center;color:var(--td3);transition:all .3s}
.fsa:hover{background:var(--red);border-color:var(--red);color:#fff}
@media(max-width:768px){.ft{grid-template-columns:1fr 1fr}}
.gs{opacity:0;transform:translateY(50px)}.gsl{opacity:0;transform:translateX(-50px)}.gss{opacity:0;transform:scale(.92)}
</style>
</head>
