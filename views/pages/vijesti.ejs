<!DOCTYPE html>
<html lang="hr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vijesti | NK Polet Sveta Klara</title>
    <link rel="icon" type="image/png" href="/Logo/657d031c9cf70ae04f623d076157e09ff63013fb.png">
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;500;600;700;800;900&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --blue: #1B2A4A;
            --red: #D42428;
            --red-l: #E84E52;
            --dark: #0F1520;
            --light: #F7F7F8;
            --white: #FFFFFF;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--light);
            color: var(--dark);
            line-height: 1.6;
        }

        /* Nav */
        .nav{position:fixed;top:0;left:0;right:0;z-index:1000;height:72px;display:flex;align-items:center;padding:0 48px;transition:all .4s;background:rgba(11,15,24,.94);backdrop-filter:blur(20px);border-bottom:1px solid rgba(255,255,255,.06)}
        .ni{display:flex;align-items:center;justify-content:space-between;width:100%}
        .nav-left{display:flex;align-items:center;gap:40px}
        .nav-brand{display:flex;align-items:center;gap:12px;text-decoration:none}
        .nav-crest{width:52px;height:52px;flex-shrink:0}.nav-crest img{width:100%;height:100%;object-fit:contain}
        .nav-name{font-family:'Barlow Condensed',sans-serif;font-size:1.3rem;font-weight:700;color:#fff;letter-spacing:.1em}
        .nav-links{display:flex;gap:28px;list-style:none}
        .nav-links a{font-size:.78rem;font-weight:600;color:rgba(113,125,143,.9);text-transform:uppercase;letter-spacing:.08em;transition:color .3s;text-decoration:none;font-family:'Inter',sans-serif}
        .nav-links a:hover{color:#fff}
        .nav-right{display:flex;align-items:center;gap:16px}
        .nav-social a{width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center;color:rgba(113,125,143,.9);transition:all .3s;text-decoration:none}
        .nav-social a:hover{color:#fff;background:rgba(255,255,255,.06)}
        .nav-toggle{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:5px;z-index:1001}
        .nav-toggle span{width:20px;height:1.5px;background:#fff;transition:all .3s;border-radius:1px}
        .nav-toggle.active span:nth-child(1){transform:rotate(45deg) translate(4.5px,4.5px)}
        .nav-toggle.active span:nth-child(2){opacity:0}
        .nav-toggle.active span:nth-child(3){transform:rotate(-45deg) translate(4.5px,-4.5px)}
        @media(max-width:1024px){
        .nav{padding:0 20px}
        .nav-toggle{display:flex;z-index:10001}
        .nav-links{position:fixed;inset:0;background:rgba(11,15,24,.97);flex-direction:column;align-items:center;justify-content:center;gap:32px;opacity:0;pointer-events:none;transition:opacity .4s;z-index:10000}
        .nav-links.open{opacity:1;pointer-events:all}
        .nav-links a{font-size:1.3rem}
        }

        /* Hero Section */
        .page-hero {
            position: relative;
            background: var(--dark);
            padding: 160px 40px 80px;
            text-align: center;
            overflow: hidden;
        }

        .page-hero::before {
            content: '';
            position: absolute;
            inset: 0;
            background:
                radial-gradient(circle at 20% 80%, rgba(212,36,40,0.15) 0%, transparent 50%),
                radial-gradient(circle at 80% 20%, rgba(27,42,74,0.3) 0%, transparent 50%);
            pointer-events: none;
        }

        /* Pitch lines decoration */
        .page-hero::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 200px;
            height: 100px;
            border: 2px solid rgba(255,255,255,0.04);
            border-bottom: none;
            border-radius: 100px 100px 0 0;
            pointer-events: none;
        }

        .hero-label {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.75rem;
            color: var(--red-l);
            letter-spacing: 4px;
            text-transform: uppercase;
            margin-bottom: 16px;
            position: relative;
            z-index: 1;
        }

        .hero-title-main {
            font-family: 'Barlow Condensed', sans-serif;
            font-weight: 900;
            font-size: clamp(3rem, 8vw, 6rem);
            color: var(--white);
            text-transform: uppercase;
            line-height: 1;
            letter-spacing: -1px;
            position: relative;
            z-index: 1;
        }

        .hero-subtitle {
            font-family: 'Inter', sans-serif;
            font-size: 1.1rem;
            color: rgba(255,255,255,0.5);
            margin-top: 16px;
            max-width: 500px;
            margin-left: auto;
            margin-right: auto;
            position: relative;
            z-index: 1;
        }

        .hero-accent-line {
            width: 60px;
            height: 4px;
            background: var(--red);
            margin: 24px auto 0;
            border-radius: 2px;
            position: relative;
            z-index: 1;
        }

        /* Filters */
        .filters-section {
            max-width: 1200px;
            margin: 0 auto;
            padding: 40px 40px 0;
        }

        .filter-bar {
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
        }

        .filter-label {
            font-family: 'Barlow Condensed', sans-serif;
            font-weight: 700;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: #999;
            margin-right: 8px;
        }

        .filter-btn {
            padding: 8px 20px;
            border: 2px solid #ddd;
            background: var(--white);
            border-radius: 30px;
            font-family: 'Barlow Condensed', sans-serif;
            font-weight: 600;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #666;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .filter-btn:hover {
            border-color: var(--red);
            color: var(--red);
        }

        .filter-btn.active {
            background: var(--red);
            border-color: var(--red);
            color: var(--white);
        }

        /* News Grid */
        .news-grid-section {
            max-width: 1200px;
            margin: 0 auto;
            padding: 40px;
        }

        .news-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
            gap: 32px;
        }

        .news-card {
            background: var(--white);
            border-radius: 16px;
            overflow: hidden;
            border: 1px solid #e8e8e8;
            transition: all 0.4s ease;
            display: flex;
            flex-direction: column;
            text-decoration: none;
            color: inherit;
        }

        .news-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 20px 50px rgba(0,0,0,0.12);
            border-color: transparent;
        }

        .card-image {
            position: relative;
            height: 220px;
            overflow: hidden;
        }

        .card-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s ease;
        }

        .news-card:hover .card-image img {
            transform: scale(1.08);
        }

        .card-image-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to bottom, transparent 50%, rgba(15,21,32,0.4) 100%);
        }

        .card-badge {
            position: absolute;
            top: 16px;
            left: 16px;
            background: var(--red);
            color: var(--white);
            font-family: 'Barlow Condensed', sans-serif;
            font-weight: 700;
            font-size: 0.7rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            padding: 5px 14px;
            border-radius: 3px;
        }

        .card-body {
            padding: 24px;
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .card-date {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.75rem;
            color: #999;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .card-date svg {
            width: 14px;
            height: 14px;
        }

        .card-title {
            font-family: 'Barlow Condensed', sans-serif;
            font-weight: 700;
            font-size: 1.3rem;
            text-transform: uppercase;
            color: var(--dark);
            line-height: 1.2;
            margin-bottom: 12px;
            transition: color 0.3s ease;
        }

        .news-card:hover .card-title {
            color: var(--red);
        }

        .card-excerpt {
            font-size: 0.9rem;
            color: #666;
            line-height: 1.6;
            flex: 1;
        }

        .card-footer {
            padding: 16px 24px;
            border-top: 1px solid #f0f0f0;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .read-more {
            font-family: 'Barlow Condensed', sans-serif;
            font-weight: 600;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--red);
            display: flex;
            align-items: center;
            gap: 6px;
            transition: gap 0.3s ease;
        }

        .news-card:hover .read-more {
            gap: 12px;
        }

        .read-more svg {
            width: 16px;
            height: 16px;
        }

        .read-time {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.7rem;
            color: #bbb;
        }

        /* Decorative pitch element */
        .pitch-decoration {
            position: fixed;
            bottom: -60px;
            right: -60px;
            width: 200px;
            height: 200px;
            border: 3px solid rgba(212,36,40,0.06);
            border-radius: 50%;
            pointer-events: none;
            z-index: 0;
        }

        .pitch-decoration::after {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 20px;
            height: 20px;
            border: 3px solid rgba(212,36,40,0.06);
            border-radius: 50%;
        }

        /* Footer */
        .site-footer {
            background: var(--dark);
            color: rgba(255,255,255,0.6);
            padding: 60px 40px 30px;
            margin-top: 40px;
        }

        .footer-inner {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            flex-wrap: wrap;
            gap: 40px;
            justify-content: space-between;
            align-items: flex-start;
        }

        .footer-brand {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .footer-brand img {
            width: 50px;
            height: 50px;
            object-fit: contain;
        }

        .footer-brand-text h4 {
            font-family: 'Barlow Condensed', sans-serif;
            font-weight: 700;
            color: var(--white);
            font-size: 1.1rem;
            text-transform: uppercase;
        }

        .footer-brand-text p { font-size: 0.8rem; }
        .footer-info p { font-size: 0.85rem; margin-bottom: 4px; }

        .footer-bottom {
            max-width: 1200px;
            margin: 40px auto 0;
            padding-top: 20px;
            border-top: 1px solid rgba(255,255,255,0.1);
            text-align: center;
            font-size: 0.8rem;
            font-family: 'JetBrains Mono', monospace;
        }

        @media (max-width: 768px) {
            .page-hero { padding: 130px 20px 60px; }
            .filters-section { padding: 30px 20px 0; }
            .news-grid-section { padding: 30px 20px; }
            .news-grid { grid-template-columns: 1fr; gap: 24px; }
            .footer-inner { flex-direction: column; gap: 24px; }
            .site-footer { padding: 40px 20px 24px; }
        }

        @media (max-width: 480px) {
            .filter-bar { gap: 8px; }
            .filter-btn { padding: 6px 14px; font-size: 0.75rem; }
        }
    </style>
</head>
<body>
    <%- include('../partials/nav', {currentPage: currentPage}) %>

    <section class="page-hero">
        <div class="hero-label">NK Polet Sveta Klara</div>
        <h1 class="hero-title-main">Vijesti</h1>
        <p class="hero-subtitle">Sve najnovije vijesti, izvještaji s utakmica, intervjui i najave iz našeg kluba.</p>
        <div class="hero-accent-line"></div>
    </section>

    <section class="filters-section">
        <div class="filter-bar">
            <span class="filter-label">Kategorija:</span>
            <button class="filter-btn active" data-filter="all">Sve</button>
            <button class="filter-btn" data-filter="utakmica">Utakmice</button>
            <button class="filter-btn" data-filter="najava">Najave</button>
            <button class="filter-btn" data-filter="intervju">Intervju</button>
            <button class="filter-btn" data-filter="klub">Klub</button>
            <button class="filter-btn" data-filter="akademija">Akademija</button>
        </div>
    </section>

    <section class="news-grid-section">
        <div class="news-grid">

            <!-- Card 1: Najava Ilovac -->
            <a href="/najava-ilovac" class="news-card" data-category="najava">
                <div class="card-image">
                    <img src="https://images.unsplash.com/photo-1560272564-c83b66b1ad12?w=800&q=80" alt="Najava utakmice" loading="lazy">
                    <div class="card-image-overlay"></div>
                    <div class="card-badge">Najava</div>
                </div>
                <div class="card-body">
                    <div class="card-date">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        24. ožujka 2026.
                    </div>
                    <h3 class="card-title">Najava: NK Ilovac - NK Polet Sveta Klara</h3>
                    <p class="card-excerpt">U subotu 28. ožujka očekuje nas gostovanje kod NK Ilovca. Polet u odličnoj formi želi nastaviti pozitivan niz...</p>
                </div>
                <div class="card-footer">
                    <span class="read-more">
                        Pročitaj više
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    </span>
                    <span class="read-time">3 min</span>
                </div>
            </a>

            <!-- Card 2: Zelengaj remi -->
            <a href="/zelengaj-remi" class="news-card" data-category="utakmica">
                <div class="card-image">
                    <img src="https://images.unsplash.com/photo-1579952363873-27f3bade9f55?w=800&q=80" alt="NK Polet vs NK Zelengaj" loading="lazy">
                    <div class="card-image-overlay"></div>
                    <div class="card-badge">Utakmica</div>
                </div>
                <div class="card-body">
                    <div class="card-date">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        21. ožujka 2026.
                    </div>
                    <h3 class="card-title">NK Polet 1-1 NK Zelengaj 1948</h3>
                    <p class="card-excerpt">Uzbudljiva utakmica na Sportskom centru Polet završila je pravednim remijem. Obje ekipe imale prilike za pobjedu...</p>
                </div>
                <div class="card-footer">
                    <span class="read-more">
                        Pročitaj više
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    </span>
                    <span class="read-time">5 min</span>
                </div>
            </a>

            <!-- Card 3: Intervju Jurić -->
            <a href="/intervju-skrinjaric" class="news-card" data-category="intervju">
                <div class="card-image">
                    <img src="https://images.unsplash.com/photo-1551958219-acbc608c6377?w=800&q=80" alt="Trener Jurić" loading="lazy">
                    <div class="card-image-overlay"></div>
                    <div class="card-badge">Intervju</div>
                </div>
                <div class="card-body">
                    <div class="card-date">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        18. ožujka 2026.
                    </div>
                    <h3 class="card-title">Intervju: Trener Sandro Jurić o ciljevima sezone</h3>
                    <p class="card-excerpt">Ekskluzivni razgovor s našim trenerom o planovima za sezonu, filozofiji igre i razvoju mladih igrača...</p>
                </div>
                <div class="card-footer">
                    <span class="read-more">
                        Pročitaj više
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    </span>
                    <span class="read-time">7 min</span>
                </div>
            </a>

            <!-- Card 4: Pobjeda Spansko -->
            <a href="/pobjeda-spansko" class="news-card" data-category="utakmica">
                <div class="card-image">
                    <img src="https://images.unsplash.com/photo-1517466787929-bc90951d0974?w=800&q=80" alt="NK Polet vs NK Spansko" loading="lazy">
                    <div class="card-image-overlay"></div>
                    <div class="card-badge">Utakmica</div>
                </div>
                <div class="card-body">
                    <div class="card-date">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        14. ožujka 2026.
                    </div>
                    <h3 class="card-title">Uvjerljiva pobjeda! NK Polet 3-1 NK Spansko</h3>
                    <p class="card-excerpt">Fantastičan dan za navijače! Gotovac dvostrukim pogotkom predvodi Polet do zaslužene pobjede protiv NK Spanskog...</p>
                </div>
                <div class="card-footer">
                    <span class="read-more">
                        Pročitaj više
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    </span>
                    <span class="read-time">4 min</span>
                </div>
            </a>

            <!-- Card 5: Infrastruktura -->
            <a href="/infrastruktura" class="news-card" data-category="klub">
                <div class="card-image">
                    <img src="https://images.unsplash.com/photo-1600679472829-3044539ce8ed?w=800&q=80" alt="Sportski centar Polet" loading="lazy">
                    <div class="card-image-overlay"></div>
                    <div class="card-badge">Klub</div>
                </div>
                <div class="card-body">
                    <div class="card-date">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        10. ožujka 2026.
                    </div>
                    <h3 class="card-title">Ulaganje u budućnost: obnova Sportskog centra Polet</h3>
                    <p class="card-excerpt">Sportski centar Polet prolazi kroz značajnu obnovu - novi travnjak, svlačionice i LED rasvjeta...</p>
                </div>
                <div class="card-footer">
                    <span class="read-more">
                        Pročitaj više
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    </span>
                    <span class="read-time">6 min</span>
                </div>
            </a>

            <!-- Card 6: Mladi igraci -->
            <a href="/mladi-igraci" class="news-card" data-category="akademija">
                <div class="card-image">
                    <img src="https://images.unsplash.com/photo-1543326727-cf6c39e8f84c?w=800&q=80" alt="Mladi igraci NK Polet" loading="lazy">
                    <div class="card-image-overlay"></div>
                    <div class="card-badge">Akademija</div>
                </div>
                <div class="card-body">
                    <div class="card-date">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        5. ožujka 2026.
                    </div>
                    <h3 class="card-title">Mladi igrači: budućnost NK Poleta Sveta Klara</h3>
                    <p class="card-excerpt">Šest igrača mlađih od 20 godina redovito nastupa za prvu momčad. Upoznajte talente koji grade budućnost kluba...</p>
                </div>
                <div class="card-footer">
                    <span class="read-more">
                        Pročitaj više
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    </span>
                    <span class="read-time">6 min</span>
                </div>
            </a>

        </div>
    </section>

    <div class="pitch-decoration"></div>

    <footer class="site-footer">
        <div class="footer-inner">
            <div class="footer-brand">
                <img src="/Logo/657d031c9cf70ae04f623d076157e09ff63013fb.png" alt="NK Polet">
                <div class="footer-brand-text">
                    <h4>NK Polet Sveta Klara</h4>
                    <p>Osnovan 1948. godine</p>
                </div>
            </div>
            <div class="footer-info">
                <p>Sportski centar Polet</p>
                <p>Sveta Klara, Zagreb</p>
                <p>info@nkpolet.hr</p>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; 2026 NK Polet Sveta Klara. Sva prava pridržana.</p>
        </div>
    </footer>

    <script>
        // Category filter functionality
        const filterBtns = document.querySelectorAll('.filter-btn');
        const newsCards = document.querySelectorAll('.news-card');

        filterBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                // Update active button
                filterBtns.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');

                const filter = btn.dataset.filter;

                newsCards.forEach(card => {
                    if (filter === 'all' || card.dataset.category === filter) {
                        card.style.display = 'flex';
                        card.style.animation = 'fadeIn 0.4s ease';
                    } else {
                        card.style.display = 'none';
                    }
                });
            });
        });

        // Simple fade-in animation
        const style = document.createElement('style');
        style.textContent = `
            @keyframes fadeIn {
                from { opacity: 0; transform: translateY(10px); }
                to { opacity: 1; transform: translateY(0); }
            }
        `;
        document.head.appendChild(style);
    </script>
<%- include('../partials/nav-js') %>
</body>
</html>