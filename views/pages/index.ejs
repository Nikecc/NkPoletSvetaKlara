<!DOCTYPE html>
<html lang="hr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Škola nogometa — NK Polet Sveta Klara</title>
<meta name="description" content="Upiši dijete u školu nogometa NK Polet Sveta Klara. Profesionalan pristup, stručan trenerski tim i tradicija od 1948.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@300;400;500;600;700;800;900&family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
--blue:#1B2A4A;--blue-l:#2C4470;--blue-d:#0F1A30;
--red:#D42428;--red-l:#E84E52;--red-d:#A01C1F;
--dark:#0B0F18;--dark-2:#111827;--dark-3:#1A2233;--dark-4:#212B3E;
--light:#F7F7F8;--light-2:#EEEEF0;--cream:#FAFAF9;--white:#FFF;
--td:#1A1A2E;--td2:#4A5568;--td3:#717D8F;
--border:rgba(255,255,255,.06);--bl:rgba(0,0,0,.06);
--r:12px;
--fh:'Barlow Condensed',sans-serif;--fb:'Inter',sans-serif;--fm:'JetBrains Mono',monospace;
}
html{scroll-behavior:smooth;overflow-x:hidden}
body{font-family:var(--fb);background:var(--light);color:var(--td);overflow-x:hidden;-webkit-font-smoothing:antialiased}
h1,h2,h3,h4,h5{font-family:var(--fh);text-transform:uppercase;letter-spacing:.02em}
.container{max-width:1320px;margin:0 auto;padding:0 48px}
@media(max-width:768px){.container{padding:0 20px}}
img{display:block;max-width:100%}a{color:inherit;text-decoration:none}
.sec{padding:100px 0}
.sec-title{font-size:clamp(2rem,4vw,2.8rem);font-weight:800;letter-spacing:.03em}
.sec-label{font-family:var(--fb);font-size:.65rem;font-weight:700;color:var(--red);text-transform:uppercase;letter-spacing:.2em;margin-bottom:12px}
.pitch-divider{display:flex;align-items:center;justify-content:center;gap:1.5rem;padding:0 0 48px}
.pitch-divider::before,.pitch-divider::after{content:'';flex:1;height:1px;background:var(--bl)}
.pitch-divider .cm{width:36px;height:36px;border:1.5px solid rgba(0,0,0,.08);border-radius:50%;position:relative}
.pitch-divider .cm::after{content:'';width:5px;height:5px;background:rgba(0,0,0,.1);border-radius:50%;position:absolute;top:50%;left:50%;transform:translate(-50%,-50%)}
.pitch-divider.light::before,.pitch-divider.light::after{background:rgba(255,255,255,.08)}
.pitch-divider.light .cm{border-color:rgba(255,255,255,.1)}
.pitch-divider.light .cm::after{background:rgba(255,255,255,.15)}

/* ===== PRELOADER ===== */
#preloader{position:fixed;inset:0;z-index:99999;background:var(--dark);display:flex;flex-direction:column;align-items:center;justify-content:center;transition:opacity .6s,visibility .6s}
#preloader.hide{opacity:0;visibility:hidden}
#preloader .plogo{width:100px;animation:pp 1.5s ease-in-out infinite}
@keyframes pp{0%,100%{transform:scale(1)}50%{transform:scale(1.06)}}
#preloader .bar{width:120px;height:2px;background:var(--dark-3);border-radius:2px;margin-top:24px;overflow:hidden}
#preloader .bar i{display:block;width:0;height:100%;background:linear-gradient(90deg,var(--red),var(--red-l));border-radius:2px;animation:lb 1.8s ease forwards}
@keyframes lb{to{width:100%}}
#preloader .ptxt{font-family:var(--fh);font-size:1.2rem;color:rgba(255,255,255,.3);letter-spacing:.25em;margin-top:16px;text-transform:uppercase}

/* ===== NAV ===== */
.nav{position:fixed;top:0;left:0;right:0;z-index:1000;height:72px;display:flex;align-items:center;padding:0 48px;transition:all .4s}
.nav::after{content:'';position:absolute;inset:0;background:rgba(11,15,24,.94);backdrop-filter:blur(20px);opacity:0;transition:opacity .4s;z-index:-1}
.nav.scrolled::after{opacity:1}
.nav.scrolled{border-bottom:1px solid var(--border)}
.ni{display:flex;align-items:center;justify-content:space-between;width:100%}
.nav-left{display:flex;align-items:center;gap:40px}
.nav-brand{display:flex;align-items:center;gap:12px}
.nav-crest{width:52px;height:52px;flex-shrink:0;transition:transform .3s}.nav-crest img{width:100%;height:100%;object-fit:contain}
.nav-brand:hover .nav-crest{transform:scale(1.08) rotate(3deg)}
.nav-name{font-family:var(--fh);font-size:1.3rem;font-weight:700;color:#fff;letter-spacing:.1em}
.nav-links{display:flex;gap:28px;list-style:none}
.nav-links a{font-size:.78rem;font-weight:600;color:var(--td3);text-transform:uppercase;letter-spacing:.08em;transition:color .3s;position:relative;font-family:var(--fb)}
.nav-links a:hover{color:#fff}
.nav-links a::after{content:'';position:absolute;bottom:-4px;left:0;width:0;height:2px;background:var(--red);transition:width .3s}
.nav-links a:hover::after{width:100%}
.nav-right{display:flex;align-items:center;gap:16px}
.nav-social a{width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center;color:var(--td3);transition:all .3s}
.nav-social a:hover{color:#fff;background:rgba(255,255,255,.06)}
.nav-toggle{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:5px}
.nav-toggle span{width:20px;height:1.5px;background:#fff;transition:all .3s;border-radius:1px}
.nav-toggle.active span:nth-child(1){transform:rotate(45deg) translate(4.5px,4.5px)}
.nav-toggle.active span:nth-child(2){opacity:0}
.nav-toggle.active span:nth-child(3){transform:rotate(-45deg) translate(4.5px,-4.5px)}
@media(max-width:1024px){.nav{padding:0 20px}.nav-toggle{display:flex;z-index:10001}.nav-links{position:fixed;inset:0;background:rgba(11,15,24,.97);flex-direction:column;align-items:center;justify-content:center;gap:32px;opacity:0;pointer-events:none;transition:opacity .4s;z-index:10000}.nav-links.open{opacity:1;pointer-events:all}.nav-links a{font-size:1.3rem}.nav-social{display:none}}

/* ===== HERO ===== */
.hero{position:relative;min-height:100vh;display:flex;align-items:center;overflow:hidden;background:var(--dark)}
.hero-bg{position:absolute;inset:0;z-index:0}
.hero-bg img{width:100%;height:100%;object-fit:cover;opacity:.35}
.hero-ov{position:absolute;inset:0;background:linear-gradient(100deg,rgba(11,15,24,.95) 0%,rgba(11,15,24,.75) 45%,rgba(27,42,74,.55) 100%);z-index:1}
.hero-pattern{position:absolute;inset:0;background-image:repeating-linear-gradient(45deg,transparent,transparent 14px,rgba(255,255,255,.015) 14px,rgba(255,255,255,.015) 15px),repeating-linear-gradient(-45deg,transparent,transparent 14px,rgba(255,255,255,.015) 14px,rgba(255,255,255,.015) 15px);z-index:1;pointer-events:none}
.hero-content{position:relative;z-index:2;width:100%;padding:120px 48px 80px;max-width:1320px;margin:0 auto}
.hero-tag{display:inline-flex;align-items:center;gap:10px;padding:8px 20px;border-radius:100px;background:rgba(212,36,40,.15);border:1px solid rgba(212,36,40,.35);font-size:.7rem;font-weight:700;color:var(--red-l);text-transform:uppercase;letter-spacing:.14em;margin-bottom:28px;font-family:var(--fb)}
.hero-tag .dot{width:7px;height:7px;border-radius:50%;background:var(--red);animation:pulse 2s infinite}
@keyframes pulse{0%,100%{transform:scale(1);opacity:1}50%{transform:scale(1.6);opacity:.4}}
.hero-title{font-size:clamp(3rem,8vw,6.5rem);font-weight:900;line-height:.92;color:#fff;margin-bottom:20px;max-width:900px}
.hero-title .thin{font-weight:300;color:rgba(255,255,255,.5);display:block;font-size:.55em;margin-bottom:8px;letter-spacing:.08em}
.hero-title .red{color:var(--red-l)}
.hero-desc{font-size:1.1rem;color:rgba(255,255,255,.6);max-width:560px;line-height:1.7;margin-bottom:36px;font-weight:300}
.hero-actions{display:flex;gap:14px;flex-wrap:wrap}
.btn{display:inline-flex;align-items:center;gap:10px;padding:16px 32px;font-family:var(--fh);font-size:1rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;border-radius:4px;border:none;cursor:pointer;transition:all .3s;text-decoration:none}
.btn svg{transition:transform .3s}
.btn:hover svg{transform:translateX(4px)}
.btn-red{background:var(--red);color:#fff}
.btn-red:hover{background:#fff;color:var(--red);transform:translateY(-2px);box-shadow:0 12px 40px rgba(0,0,0,.3)}
.btn-wa{background:rgba(255,255,255,.08);color:#fff;border:1.5px solid rgba(255,255,255,.22);backdrop-filter:blur(10px)}
.btn-wa:hover{background:#fff;color:var(--blue-d);border-color:#fff;transform:translateY(-2px);box-shadow:0 12px 40px rgba(0,0,0,.25)}
.btn-wa svg.wa{width:18px;height:18px}
.btn-wo{background:transparent;color:#fff;border:1.5px solid rgba(255,255,255,.25)}
.btn-wo:hover{background:rgba(255,255,255,.08);border-color:rgba(255,255,255,.5)}
.btn-dark{background:var(--td);color:#fff}
.btn-dark:hover{background:var(--red);transform:translateY(-2px)}
.hero-stats{display:flex;gap:36px;margin-top:48px;padding-top:32px;border-top:1px solid rgba(255,255,255,.1);max-width:640px}
.hs-item .v{font-family:var(--fh);font-size:2.4rem;font-weight:900;color:#fff;line-height:1}
.hs-item .v .plus{color:var(--red-l)}
.hs-item .l{font-family:var(--fb);font-size:.6rem;color:rgba(255,255,255,.4);text-transform:uppercase;letter-spacing:.14em;margin-top:6px}
@media(max-width:768px){.hero-content{padding:100px 20px 60px}.hero-stats{gap:20px;flex-wrap:wrap}.hs-item .v{font-size:1.8rem}}

/* ===== UPISNICA ===== */
.enroll{background:var(--light);padding:110px 0;position:relative;overflow:hidden}
.enroll::before{content:'';position:absolute;top:-100px;left:-100px;width:400px;height:400px;background:radial-gradient(circle,rgba(212,36,40,.06),transparent 70%);border-radius:50%;pointer-events:none}
.enroll::after{content:'';position:absolute;bottom:-120px;right:-120px;width:500px;height:500px;background:radial-gradient(circle,rgba(27,42,74,.06),transparent 70%);border-radius:50%;pointer-events:none}
.enroll .container{position:relative;z-index:1}
.enroll-wrap{background:linear-gradient(135deg,var(--blue-d) 0%,var(--blue) 60%,#243659 100%);border-radius:24px;overflow:hidden;position:relative;box-shadow:0 30px 80px rgba(15,26,48,.25)}
.enroll-wrap::before{content:'';position:absolute;inset:0;background-image:repeating-linear-gradient(45deg,transparent,transparent 14px,rgba(255,255,255,.015) 14px,rgba(255,255,255,.015) 15px),repeating-linear-gradient(-45deg,transparent,transparent 14px,rgba(255,255,255,.015) 14px,rgba(255,255,255,.015) 15px);pointer-events:none}
.enroll-wrap::after{content:'POLET';position:absolute;font-family:var(--fh);font-size:22rem;font-weight:900;color:rgba(255,255,255,.025);right:-80px;bottom:-140px;line-height:1;white-space:nowrap;letter-spacing:.02em;pointer-events:none}
.enroll-grid{display:grid;grid-template-columns:1.2fr 1fr;position:relative;z-index:1}
@media(max-width:960px){.enroll-grid{grid-template-columns:1fr}}
.enroll-left{padding:64px 56px}
@media(max-width:768px){.enroll-left{padding:48px 28px}}
.enroll-left .sl{display:inline-flex;align-items:center;gap:10px;padding:7px 16px;border-radius:100px;background:rgba(212,36,40,.14);border:1px solid rgba(212,36,40,.3);font-family:var(--fb);font-size:.62rem;font-weight:700;color:var(--red-l);text-transform:uppercase;letter-spacing:.18em;margin-bottom:22px}
.enroll-left .sl .dot{width:6px;height:6px;border-radius:50%;background:var(--red);animation:pulse 2s infinite}
.enroll-left h2{font-family:var(--fh);font-size:clamp(2.2rem,4vw,3.2rem);font-weight:900;color:#fff;line-height:1.02;margin-bottom:20px}
.enroll-left h2 .red{color:var(--red-l)}
.enroll-left .lead{color:rgba(255,255,255,.62);line-height:1.75;margin-bottom:32px;font-size:.96rem;max-width:520px}
.check-list{list-style:none;display:grid;grid-template-columns:1fr 1fr;gap:12px 20px;margin:0 0 36px}
@media(max-width:560px){.check-list{grid-template-columns:1fr}}
.check-list li{display:flex;align-items:center;gap:12px;color:rgba(255,255,255,.85);font-size:.88rem;font-weight:500}
.check-list .ck{width:28px;height:28px;border-radius:8px;background:linear-gradient(135deg,var(--red),var(--red-d));color:#fff;display:flex;align-items:center;justify-content:center;flex-shrink:0;box-shadow:0 4px 14px rgba(212,36,40,.3)}
.enroll-actions{display:flex;gap:12px;flex-wrap:wrap}
.enroll-right{background:rgba(255,255,255,.025);border-left:1px solid rgba(255,255,255,.06);padding:56px 44px;display:flex;flex-direction:column;justify-content:center;gap:18px;position:relative}
@media(max-width:960px){.enroll-right{border-left:none;border-top:1px solid rgba(255,255,255,.06);padding:44px 28px}}
.er-title{font-family:var(--fb);font-size:.6rem;font-weight:700;color:rgba(255,255,255,.4);text-transform:uppercase;letter-spacing:.2em;margin-bottom:6px}
.er-stat{display:flex;align-items:center;gap:18px;padding:22px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);border-radius:14px;transition:all .35s}
.er-stat:hover{background:rgba(255,255,255,.07);border-color:rgba(212,36,40,.35);transform:translateX(4px)}
.er-stat .ic{width:48px;height:48px;border-radius:12px;background:linear-gradient(135deg,rgba(212,36,40,.2),rgba(212,36,40,.05));border:1px solid rgba(212,36,40,.25);display:flex;align-items:center;justify-content:center;color:var(--red-l);flex-shrink:0}
.er-stat .ic svg{width:20px;height:20px}
.er-stat .lb{font-family:var(--fb);font-size:.58rem;color:rgba(255,255,255,.4);text-transform:uppercase;letter-spacing:.15em;margin-bottom:3px}
.er-stat .vl{font-family:var(--fh);font-size:1.15rem;font-weight:700;color:#fff;letter-spacing:.02em;word-break:break-word;overflow-wrap:anywhere}
.er-stat > div:last-child{min-width:0;flex:1}
@media(max-width:768px){
.enroll{padding:70px 0}
.enroll-wrap{border-radius:18px}
.enroll-wrap::after{font-size:14rem;right:-60px;bottom:-90px}
.enroll-left{padding:40px 24px}
.enroll-left .sl{font-size:.58rem;padding:6px 14px;margin-bottom:18px}
.enroll-left h2{font-size:1.9rem;margin-bottom:14px}
.enroll-left .lead{font-size:.88rem;margin-bottom:24px;line-height:1.65}
.check-list{gap:10px;margin-bottom:26px}
.check-list li{font-size:.84rem}
.check-list .ck{width:24px;height:24px;border-radius:7px}
.check-list .ck svg{width:12px;height:12px}
.enroll-actions{flex-direction:column;gap:10px;width:100%}
.enroll-actions .btn{width:100%;justify-content:center;padding:14px 24px;font-size:.88rem}
.enroll-right{padding:32px 22px;gap:12px}
.er-title{margin-bottom:2px}
.er-stat{padding:16px;gap:14px;border-radius:12px}
.er-stat .ic{width:42px;height:42px;border-radius:10px}
.er-stat .ic svg{width:18px;height:18px}
.er-stat .lb{font-size:.54rem}
.er-stat .vl{font-size:.92rem}
.er-stat:hover{transform:none}
}
@media(max-width:400px){
.er-stat .vl{font-size:.82rem}
.enroll-left h2{font-size:1.7rem}
}

/* ===== AGE GROUPS ===== */
.ages{background:var(--light);padding:120px 0;position:relative}
.ages .head{text-align:center;margin-bottom:56px}
.ages .head .sec-label{color:var(--red)}
.ages .head .sec-title{color:var(--td)}
.ages .head .sub{color:var(--td2);margin-top:14px;font-size:.95rem;max-width:580px;margin-left:auto;margin-right:auto;line-height:1.7}
.ages-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px}
@media(max-width:1024px){.ages-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:480px){.ages-grid{grid-template-columns:1fr}}
.age-card{background:var(--white);border-radius:16px;padding:32px 28px;transition:all .35s;position:relative;overflow:hidden;border:1px solid var(--bl);box-shadow:0 4px 20px rgba(15,26,48,.04)}
.age-card::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;background:var(--red);transform:scaleY(0);transform-origin:top;transition:transform .35s}
.age-card:hover{transform:translateY(-5px);box-shadow:0 20px 50px rgba(15,26,48,.1);border-color:transparent}
.age-card:hover::before{transform:scaleY(1)}
.age-card .n{font-family:var(--fm);font-size:.62rem;color:var(--red);font-weight:700;letter-spacing:.18em;text-transform:uppercase;margin-bottom:14px}
.age-card h3{font-family:var(--fh);font-size:1.7rem;font-weight:900;color:var(--td);letter-spacing:.02em;line-height:1;margin-bottom:8px}
.age-card .yr{font-family:var(--fb);font-size:.82rem;color:var(--td3);font-weight:500}
.age-card .meta{margin-top:20px;padding-top:16px;border-top:1px solid var(--bl);font-family:var(--fb);font-size:.78rem;color:var(--td2);font-weight:500}

/* ===== PROLJETNA LIGA ===== */
.liga{background:var(--dark);position:relative;overflow:hidden;padding:110px 0}
.liga::before{content:'';position:absolute;inset:0;background-image:repeating-linear-gradient(45deg,transparent,transparent 14px,rgba(255,255,255,.012) 14px,rgba(255,255,255,.012) 15px),repeating-linear-gradient(-45deg,transparent,transparent 14px,rgba(255,255,255,.012) 14px,rgba(255,255,255,.012) 15px);pointer-events:none}
.liga::after{content:'';position:absolute;top:-100px;right:-100px;width:500px;height:500px;background:radial-gradient(circle,rgba(212,36,40,.08),transparent 70%);border-radius:50%;pointer-events:none}
.liga .container{position:relative;z-index:1}
.liga-head{text-align:center;margin-bottom:64px}
.liga-head .tag{display:inline-flex;align-items:center;gap:8px;padding:8px 20px;background:rgba(212,36,40,.1);border:1px solid rgba(212,36,40,.3);border-radius:100px;color:var(--red-l);font-family:var(--fm);font-size:.68rem;font-weight:600;text-transform:uppercase;letter-spacing:.15em;margin-bottom:20px}
.liga-head h2{font-family:var(--fh);font-size:clamp(2.2rem,5vw,3.6rem);font-weight:900;color:#fff;margin-bottom:16px;line-height:1.02}
.liga-head .sub{color:rgba(255,255,255,.5);font-size:1rem;max-width:680px;margin:0 auto;line-height:1.7}
.liga-info{display:grid;grid-template-columns:1.15fr .85fr;gap:28px;margin-bottom:28px}
@media(max-width:900px){.liga-info{grid-template-columns:1fr}}
.li-box{background:var(--dark-2);border:1px solid var(--border);border-radius:16px;padding:36px 34px}
.li-box h3{font-family:var(--fh);font-size:1.3rem;font-weight:800;color:#fff;margin-bottom:20px;display:flex;align-items:center;gap:10px;letter-spacing:.04em}
.li-box h3 .ic{width:34px;height:34px;border-radius:8px;background:rgba(212,36,40,.12);display:flex;align-items:center;justify-content:center;color:var(--red-l)}
.li-box h3 .ic svg{width:17px;height:17px}
.clubs-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
@media(max-width:560px){.clubs-grid{grid-template-columns:repeat(2,1fr)}}
.club-chip{padding:12px 14px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);border-radius:9px;font-family:var(--fh);font-size:.88rem;font-weight:600;color:rgba(255,255,255,.85);text-align:center;transition:all .3s;letter-spacing:.03em}
.club-chip:hover{background:rgba(212,36,40,.08);border-color:rgba(212,36,40,.3);color:#fff}
.club-chip.us{background:linear-gradient(135deg,rgba(212,36,40,.2),rgba(212,36,40,.1));border-color:var(--red);color:#fff}
.rule-list{list-style:none;display:flex;flex-direction:column;gap:12px}
.rule-list li{display:flex;align-items:flex-start;gap:12px;padding:10px 0;border-bottom:1px solid rgba(255,255,255,.04);color:rgba(255,255,255,.75);font-size:.88rem;line-height:1.5}
.rule-list li:last-child{border:none}
.rule-list .rk{font-family:var(--fh);font-size:.62rem;font-weight:700;color:var(--red-l);letter-spacing:.12em;text-transform:uppercase;margin-right:6px;min-width:80px}
.liga-goals{background:linear-gradient(135deg,rgba(212,36,40,.1),rgba(27,42,74,.1));border:1px solid rgba(255,255,255,.06);border-radius:16px;padding:40px;margin-bottom:28px}
.liga-goals h3{font-family:var(--fh);color:#fff;font-size:1.3rem;margin-bottom:24px;display:flex;align-items:center;gap:10px}
.liga-goals .ic{width:34px;height:34px;border-radius:8px;background:rgba(212,36,40,.15);display:flex;align-items:center;justify-content:center;color:var(--red-l)}
.liga-goals .ic svg{width:17px;height:17px}
.goals-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px}
@media(max-width:800px){.goals-grid{grid-template-columns:repeat(2,1fr)}}
