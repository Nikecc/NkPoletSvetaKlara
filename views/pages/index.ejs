.code-box .cd{font-family:var(--fm);font-size:1.5rem;font-weight:700;color:#fff;letter-spacing:.08em}
.oprema-list{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:18px;padding:36px 32px}
.oprema-list h3{font-family:var(--fh);font-size:1rem;font-weight:700;color:rgba(255,255,255,.5);text-transform:uppercase;letter-spacing:.15em;margin-bottom:24px;text-align:center}
.oprema-list ul{list-style:none;display:flex;flex-direction:column;gap:14px}
.oprema-list li{display:flex;align-items:center;gap:16px;padding:16px 20px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);border-radius:10px;transition:all .3s}
.oprema-list li:hover{background:rgba(255,255,255,.06);transform:translateX(4px)}
.oprema-list .num{width:32px;height:32px;border-radius:50%;background:var(--red);color:#fff;display:flex;align-items:center;justify-content:center;font-family:var(--fh);font-size:.85rem;font-weight:800;flex-shrink:0}
.oprema-list .tx{font-family:var(--fh);font-size:1rem;font-weight:600;color:#fff;letter-spacing:.03em}

