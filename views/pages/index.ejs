.goal-item .t{font-family:var(--fh);font-size:.95rem;font-weight:700;color:#fff;margin-bottom:4px;letter-spacing:.02em}
.goal-item .d{font-size:.78rem;color:rgba(255,255,255,.5);line-height:1.5}
.liga-org{display:flex;gap:28px;justify-content:center;flex-wrap:wrap;padding-top:20px;border-top:1px solid rgba(255,255,255,.06)}
.org-item{text-align:center}
.org-item .lb{font-family:var(--fb);font-size:.58rem;color:var(--td3);text-transform:uppercase;letter-spacing:.15em;margin-bottom:4px}
.org-item .nm{font-family:var(--fh);font-size:1.05rem;font-weight:700;color:#fff}

/* ===== FIZIO RESTART ===== */
.fizio{background:var(--white);padding:120px 0;position:relative;overflow:hidden}
.fizio::before{content:'';position:absolute;top:40%;left:-200px;width:500px;height:500px;background:radial-gradient(circle,rgba(212,36,40,.04),transparent 70%);border-radius:50%}
.fizio .container{position:relative;z-index:1}
.fizio-head{text-align:center;margin-bottom:64px;max-width:780px;margin-left:auto;margin-right:auto}
.fizio-head .sl{display:inline-flex;align-items:center;gap:10px;padding:7px 18px;border-radius:100px;background:rgba(212,36,40,.08);border:1px solid rgba(212,36,40,.25);font-family:var(--fb);font-size:.62rem;font-weight:700;color:var(--red);text-transform:uppercase;letter-spacing:.18em;margin-bottom:20px}
.fizio-head h2{font-family:var(--fh);font-size:clamp(2.2rem,4.5vw,3.4rem);font-weight:900;color:var(--td);line-height:1.02;margin-bottom:16px}
.fizio-head h2 .red{color:var(--red)}
.fizio-head p{color:var(--td2);line-height:1.75;font-size:1rem;max-width:640px;margin:0 auto}
.fizio-main{display:grid;grid-template-columns:1.15fr 1fr;gap:40px;align-items:stretch;margin-bottom:40px}
@media(max-width:960px){.fizio-main{grid-template-columns:1fr}}
.fizio-gallery{position:relative;min-height:560px}
@media(max-width:560px){.fizio-gallery{min-height:420px}}
.fg-img{position:absolute;border-radius:16px;overflow:hidden;box-shadow:0 24px 60px rgba(15,26,48,.2);transition:transform .5s}
.fg-img img{width:100%;height:100%;object-fit:cover}
.fg-img::after{content:'';position:absolute;inset:0;border:1px solid rgba(255,255,255,.1);border-radius:16px;pointer-events:none}
.fg-img.a{top:0;left:0;width:62%;height:70%;z-index:2}
.fg-img.a:hover{transform:translate(-6px,-6px)}
.fg-img.b{top:18%;right:0;width:48%;height:58%;z-index:3;border:4px solid var(--white)}
.fg-img.b:hover{transform:translate(6px,-6px)}
.fg-img.c{bottom:0;left:14%;width:56%;height:42%;z-index:1}
.fg-img.c:hover{transform:translate(0,6px)}
.fg-badge{position:absolute;bottom:0;right:0;z-index:4;background:linear-gradient(135deg,var(--red),var(--red-d));color:#fff;padding:22px 26px;border-radius:14px;box-shadow:0 20px 50px rgba(212,36,40,.35);max-width:220px}
.fg-badge .sm{font-family:var(--fb);font-size:.58rem;font-weight:700;text-transform:uppercase;letter-spacing:.15em;opacity:.85;margin-bottom:4px}
.fg-badge .lg{font-family:var(--fh);font-size:1.2rem;font-weight:900;line-height:1.1}
.fizio-info{display:flex;flex-direction:column;gap:14px}
.fi-title{font-family:var(--fh);font-size:.72rem;font-weight:700;color:var(--td3);text-transform:uppercase;letter-spacing:.2em;margin-bottom:4px}
.fi-card{padding:22px 24px;background:var(--light);border:1px solid var(--bl);border-radius:14px;display:flex;align-items:center;gap:18px;transition:all .35s;position:relative;overflow:hidden}
.fi-card::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;background:var(--red);transform:scaleY(0);transform-origin:top;transition:transform .35s}
.fi-card:hover{border-color:transparent;background:var(--white);transform:translateX(6px);box-shadow:0 16px 40px rgba(0,0,0,.08)}
.fi-card:hover::before{transform:scaleY(1)}
.fi-card .ic{width:52px;height:52px;border-radius:12px;background:linear-gradient(135deg,rgba(212,36,40,.12),rgba(212,36,40,.04));border:1px solid rgba(212,36,40,.2);display:flex;align-items:center;justify-content:center;color:var(--red);flex-shrink:0}
.fi-card .ic svg{width:22px;height:22px}
.fi-card .tag{font-family:var(--fb);font-size:.55rem;font-weight:700;color:var(--red);text-transform:uppercase;letter-spacing:.15em;margin-bottom:4px}
.fi-card .tl{font-family:var(--fh);font-size:1.1rem;font-weight:800;color:var(--td);letter-spacing:.02em;margin-bottom:2px}
.fi-card .ds{font-size:.82rem;color:var(--td3);font-weight:500}
.fi-card .bg{margin-left:auto;font-family:var(--fh);font-size:2rem;font-weight:900;color:var(--red);line-height:1}
.fizio-bottom{display:grid;grid-template-columns:1.4fr 1fr;gap:20px;align-items:center}
@media(max-width:800px){.fizio-bottom{grid-template-columns:1fr}}
.fizio-warn{display:flex;align-items:center;gap:16px;padding:22px 28px;background:linear-gradient(135deg,var(--dark-2),var(--dark));border-radius:14px;border:1px solid var(--border);position:relative;overflow:hidden}
.fizio-warn::before{content:'';position:absolute;left:0;top:0;bottom:0;width:4px;background:linear-gradient(180deg,var(--red),var(--red-l))}
.fizio-warn .ic{width:44px;height:44px;border-radius:50%;background:rgba(212,36,40,.12);display:flex;align-items:center;justify-content:center;color:var(--red-l);flex-shrink:0}
.fizio-warn .ic svg{width:20px;height:20px}
.fizio-warn .tx{color:#fff;font-family:var(--fh);font-size:1.1rem;font-weight:700;letter-spacing:.02em}
.fizio-warn .sb{color:rgba(255,255,255,.55);font-family:var(--fb);font-size:.78rem;margin-top:2px;font-weight:400;text-transform:none;letter-spacing:0}
.fizio-contact{display:flex;gap:10px;flex-wrap:wrap;justify-content:flex-end}
@media(max-width:800px){.fizio-contact{justify-content:flex-start}}
.fc-item{display:flex;align-items:center;gap:10px;padding:14px 18px;background:var(--white);border:1px solid var(--bl);border-radius:12px;font-size:.82rem;color:var(--td);font-family:var(--fb);font-weight:600;transition:all .3s}
.fc-item:hover{border-color:var(--red);color:var(--red);transform:translateY(-2px);box-shadow:0 10px 24px rgba(212,36,40,.1)}
.fc-item svg{width:15px;height:15px;color:var(--red)}

/* ===== OPREMA ===== */
.oprema{background:linear-gradient(135deg,var(--blue-d) 0%,var(--blue) 100%);padding:110px 0;position:relative;overflow:hidden}
.oprema::before{content:'';position:absolute;inset:0;background-image:repeating-linear-gradient(45deg,transparent,transparent 14px,rgba(255,255,255,.012) 14px,rgba(255,255,255,.012) 15px)}
.oprema::after{content:'';position:absolute;top:50%;left:-100px;width:400px;height:400px;background:radial-gradient(circle,rgba(212,36,40,.1),transparent 70%);border-radius:50%;transform:translateY(-50%)}
.oprema .container{position:relative;z-index:1}
.oprema-grid{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center}
@media(max-width:900px){.oprema-grid{grid-template-columns:1fr}}
.oprema-text .sl{font-family:var(--fb);font-size:.65rem;font-weight:700;color:var(--red-l);text-transform:uppercase;letter-spacing:.2em;margin-bottom:14px}
.oprema-text h2{font-family:var(--fh);font-size:clamp(2rem,4vw,3rem);font-weight:900;color:#fff;margin-bottom:18px;line-height:1.05}
.oprema-text p{color:rgba(255,255,255,.6);line-height:1.75;margin-bottom:28px;font-size:.95rem;max-width:540px}
.code-box{background:rgba(255,255,255,.04);border:1px dashed rgba(255,255,255,.18);border-radius:12px;padding:20px 24px;margin-bottom:28px;max-width:440px}
