function ptRenderCategory(key){
  const cat=ptCategories[key];if(!cat)return;
  const c=document.getElementById('ptCatContent');
  let h=`<div class="pt-cat-content" id="ptActiveContent"><div class="pt-league-header"><div class="pt-league-title">${cat.league}</div><div class="pt-league-badge">Sezona 2025./2026.</div></div><div class="pt-table-wrap"><table class="pt-league-table"><thead><tr><th>#</th><th>Klub</th><th>UT</th><th>P</th><th>N</th><th>I</th><th>G+</th><th>G-</th><th>GR</th><th>Bod</th></tr></thead><tbody>`;
  cat.table.forEach(r=>{const isP=r[1]===cat.poletName;const pc=r[0]<=3?' pt-pos-'+r[0]:'';h+=`<tr class="${isP?'pt-highlight':''}"><td><span class="pt-pos-badge${pc}">${r[0]}</span></td><td>${r[1]}</td><td>${r[2]}</td><td>${r[3]}</td><td>${r[4]}</td><td>${r[5]}</td><td>${r[6]}</td><td>${r[7]}</td><td>${r[8]}</td><td>${r[9]}</td></tr>`});
  h+=`</tbody></table></div><div class="pt-roster-header">Popis igrača <span class="count">(${cat.players.length} igrača)</span></div><div class="pt-roster-grid">`;
  cat.players.forEach(p=>{const gk=p.pos==='GK';const nd=p.num!==null?p.num:'—';h+=`<div class="pt-player-card${gk?' gk':''}"><div class="pt-player-num${p.num===null?' no-num':''}">${nd}</div><div><div class="pt-player-name">${p.n}</div>${gk?'<div class="pt-player-pos">Vratar</div>':''}</div></div>`});
  h+=`</div></div>`;
  c.innerHTML=h;
  requestAnimationFrame(()=>{const el=document.getElementById('ptActiveContent');if(el)requestAnimationFrame(()=>el.classList.add('visible'))});
}
document.querySelectorAll('#ptCatTabs .pt-cat-tab').forEach(t=>{t.addEventListener('click',function(){document.querySelectorAll('#ptCatTabs .pt-cat-tab').forEach(x=>x.classList.remove('active'));this.classList.add('active');const k=this.dataset.cat;document.getElementById('ptCatDropdown').value=k;ptRenderCategory(k)})});
document.getElementById('ptCatDropdown').addEventListener('change',function(){const k=this.value;document.querySelectorAll('#ptCatTabs .pt-cat-tab').forEach(t=>t.classList.toggle('active',t.dataset.cat===k));ptRenderCategory(k)});
ptRenderCategory('juniori');
