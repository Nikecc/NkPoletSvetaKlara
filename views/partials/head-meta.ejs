<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= seo.title %></title>
<meta name="description" content="<%= seo.description %>">
<link rel="canonical" href="<%= siteUrl %><%= seo.path %>">
<meta name="robots" content="index, follow">
<meta name="theme-color" content="#D42428">
<meta name="author" content="NK Polet Sveta Klara">
<link rel="icon" type="image/png" href="/Logo/657d031c9cf70ae04f623d076157e09ff63013fb.png">
<link rel="apple-touch-icon" href="/Logo/657d031c9cf70ae04f623d076157e09ff63013fb.png">
<!-- Open Graph -->
<meta property="og:type" content="<%= seo.type || 'website' %>">
<meta property="og:site_name" content="NK Polet Sveta Klara">
<meta property="og:locale" content="hr_HR">
<meta property="og:title" content="<%= seo.title %>">
<meta property="og:description" content="<%= seo.description %>">
<meta property="og:url" content="<%= siteUrl %><%= seo.path %>">
<meta property="og:image" content="<%= siteUrl %>/Logo/657d031c9cf70ae04f623d076157e09ff63013fb.png">
<meta property="og:image:alt" content="Grb NK Polet Sveta Klara">
<!-- Twitter -->
<meta name="twitter:card" content="summary">
<meta name="twitter:title" content="<%= seo.title %>">
<meta name="twitter:description" content="<%= seo.description %>">
<meta name="twitter:image" content="<%= siteUrl %>/Logo/657d031c9cf70ae04f623d076157e09ff63013fb.png">
